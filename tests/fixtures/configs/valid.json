{
  "embedder": {
    "model_name": "Qwen/Qwen3-VL-Embedding-2B",
    "device": "cpu",
    "torch_dtype": "float32",
    "embedding_dimension": 2048,
    "max_length": 8192,
    "batch_size": 16,
    "normalize": true,
    "trust_remote_code": true,
    "lru_cache_size": 512
  },
  "store": {
    "db_path": "test.db",
    "wal_mode": true
  },
  "chunk": {
    "strategy": "auto",
    "max_tokens": 512,
    "overlap_tokens": 64
  },
  "pipeline": {
    "collection": "test-collection",
    "concurrency": 2
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8585,
    "workers": 1,
    "log_level": "info"
  }
}
